# Word Circles backend configuration.
#
# NOTE: the backend does NOT auto-load this file. In production env comes from
# the DAppNode docker-compose `environment:` block. To use these values locally
# (e.g. `cargo run` or the bot_join_once smoke test), export them first:
#   set -a && source .env && set +a && cargo run
# (or run the binary under a tool that loads .env).

# Server
PORT=3001

# Postgres connection (rindexer + app share this DB). Required.
DATABASE_URL=postgres://user:password@host:5432/wordcircles

# PvP mode. The frontend reads pvpEnabled from /api/config at runtime.
PVP_ENABLED=false
PVP_TIMEOUT_SECS=10800

# Indexer (polls rindexer's wc_* event tables in the same Postgres).
INDEXER_POLL_SECS=5

# Settlement timeout loop.
TIMEOUT_POLL_SECS=30

# Dune bootstrap (cargo run -- bootstrap).
# DUNE_API_KEY=your_dune_api_key
# DUNE_QUERY_ID=7572687

# Resolver wallet — enables on-chain commit/reveal/resolve. Required for PvP.
# RESOLVER_PRIVATE_KEY=0x...
# RPC_URL=https://rpc.gnosischain.com
COMMITMENT_ADDRESS=0x6e99c40bd8b87290EB977336c4Be8b2106baB08f
ESCROW_ADDRESS=0x20a44c2C546FEBb4dcE773868B532D14663467A0
STATS_ADDRESS=0xB96413584d7a4e07cc8c238cC4baA3474C956CCF

# PvP lobbies — one per supported Circles group. JSON array; each entry is
# {name, group, token, amount, capacity?} (capacity defaults to 2). `token` is
# the group's s-gCRC wrapper, validated at startup against erc20Circles(1, group).
# The frontend shows a lobby only when it's bot-funded AND the player is a member
# of `group`. See docs/multi-group-pvp.md.
# PVP_LOBBIES=[{"name":"WordGames","group":"0xb84ea90430c98ff314b803a036c9ca745b797932","token":"0x872e67dBBF6d76A7484fcA6C4B99053334Bb6C0E","amount":"100000000000000000","capacity":2}]

# Onboarding group the app trusts players into (POST /api/group/join after a
# daily win). The resolver EOA must be the group's owner/service (call
# setService(resolver) on the group once). Usually the first PVP_LOBBIES group.
# GROUP_ADDRESS=0xb84ea90430c98ff314b803a036c9ca745b797932

# Matchmaking bot. Plays as the Circles account (Safe) at BOT_SAFE_ADDRESS,
# signed by an owner EOA (BOT_PRIVATE_KEY). The Safe must hold each lobby's
# wrapper token (>= 2x stake) for that lobby to be advertised as enterable.
BOT_ENABLED=false
# BOT_SAFE_ADDRESS=0x335D5a9adA218A2b334c5E17242D15158e7380f9
# BOT_PRIVATE_KEY=0x...
BOT_JOIN_DELAY_SECS=60
BOT_POLL_SECS=15
