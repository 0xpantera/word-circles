{
  "openapi": "3.1.0",
  "info": {
    "title": "Word Circles API",
    "description": "Backend API for the Word Circles daily word game",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/config": {
      "get": {
        "tags": [],
        "operationId": "get_config",
        "responses": {
          "200": {
            "description": "Contract configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContractConfig"
                }
              }
            }
          },
          "503": {
            "description": "Resolver not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/game": {
      "get": {
        "tags": [],
        "operationId": "get_game",
        "parameters": [
          {
            "name": "player",
            "in": "query",
            "description": "0x-prefixed player address. When provided, the response includes the\nplayer's recorded guesses so a client with no local state can rehydrate.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current daily game",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/games": {
      "get": {
        "tags": [],
        "operationId": "get_player_games",
        "parameters": [
          {
            "name": "player",
            "in": "query",
            "description": "Player address (0x-prefixed) to look up PvP games for.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "active",
            "in": "query",
            "description": "Limit to games still in progress (waiting/active).",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PvP games for a player, most recent first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PvpGameResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid player address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/games/{game_id}": {
      "get": {
        "tags": [],
        "operationId": "get_pvp_game",
        "parameters": [
          {
            "name": "game_id",
            "in": "path",
            "description": "PvP game ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PvP game state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PvpGameResponse"
                }
              }
            }
          },
          "404": {
            "description": "Game not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/games/{game_id}/transcript": {
      "get": {
        "tags": [],
        "operationId": "get_pvp_transcript",
        "parameters": [
          {
            "name": "game_id",
            "in": "path",
            "description": "PvP game ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Both players' guess transcripts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PvpTranscript"
                }
              }
            }
          },
          "404": {
            "description": "Game not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Game not settled yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/group/join": {
      "post": {
        "tags": [],
        "operationId": "post_group_join",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GroupJoinRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Player onboarded into the group",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupJoinResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid player address or signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Signature does not match player",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "No recorded play for this address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Trust transaction failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Group onboarding not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/guess": {
      "post": {
        "tags": [],
        "operationId": "post_guess",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuessRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Guess evaluation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid guess",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/leaderboard": {
      "get": {
        "tags": [],
        "operationId": "get_leaderboard",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Leaderboard entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LeaderboardEntry"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/leaderboard/daily": {
      "get": {
        "tags": [],
        "operationId": "get_daily_leaderboard",
        "parameters": [
          {
            "name": "gameId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily game results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyResult"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContractConfig": {
        "type": "object",
        "required": [
          "resolver",
          "commitmentAddress",
          "pvpEnabled",
          "lobbies"
        ],
        "properties": {
          "commitmentAddress": {
            "type": "string"
          },
          "escrowAddress": {
            "type": [
              "string",
              "null"
            ]
          },
          "lobbies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LobbyConfig"
            },
            "description": "Configured PvP lobbies (one per supported group). The frontend shows the\nones the player is a group member of; each lobby's `botFunded` flag drives\na \"no bot backstop\" warning rather than hiding the lobby."
          },
          "pvpEnabled": {
            "type": "boolean"
          },
          "resolver": {
            "type": "string"
          },
          "statsAddress": {
            "type": [
              "string",
              "null"
            ]
          },
          "timeoutSecs": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "Per-player play window before a forced timeout, in seconds.",
            "minimum": 0
          }
        }
      },
      "DailyResult": {
        "type": "object",
        "required": [
          "address",
          "guesses",
          "solved"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "guesses": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "solved": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "GameResponse": {
        "type": "object",
        "required": [
          "gameId"
        ],
        "properties": {
          "answer": {
            "type": [
              "string",
              "null"
            ],
            "description": "The day's answer, only revealed once the player's game is over (won or\nlost). Withheld while they're still playing."
          },
          "gameId": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "guesses": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/PlayerGuess"
            },
            "description": "Player's recorded guesses for this game, in order. Only populated when\n`?player=` is provided. An empty vec means the player hasn't guessed yet."
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "description": "\"playing\" | \"won\" | \"lost\" derived from `guesses`. Only set when\n`?player=` is provided."
          }
        }
      },
      "GroupJoinRequest": {
        "type": "object",
        "required": [
          "player",
          "signature"
        ],
        "properties": {
          "player": {
            "type": "string",
            "description": "Player address (0x-prefixed) to onboard into the PvP group."
          },
          "signature": {
            "type": "string",
            "description": "Hex signature over [`group_join_message`] proving control of `player`\n(ECDSA for an EOA, or an ERC-1271 contract signature for a Safe avatar)."
          }
        }
      },
      "GroupJoinResponse": {
        "type": "object",
        "required": [
          "joined",
          "alreadyMember"
        ],
        "properties": {
          "alreadyMember": {
            "type": "boolean",
            "description": "True if they were already a member (no transaction was sent)."
          },
          "joined": {
            "type": "boolean",
            "description": "True once the player is trusted by the group (newly or already)."
          }
        }
      },
      "GuessRequest": {
        "type": "object",
        "required": [
          "guess",
          "gameId",
          "guessNumber"
        ],
        "properties": {
          "gameId": {
            "type": "string"
          },
          "guess": {
            "type": "string"
          },
          "guessNumber": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "player": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "GuessResponse": {
        "type": "object",
        "required": [
          "guess",
          "results",
          "won",
          "gameOver"
        ],
        "properties": {
          "answer": {
            "type": [
              "string",
              "null"
            ]
          },
          "gameOver": {
            "type": "boolean"
          },
          "guess": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LetterResult"
            }
          },
          "won": {
            "type": "boolean"
          }
        }
      },
      "LeaderboardEntry": {
        "type": "object",
        "required": [
          "address",
          "wins",
          "games_played",
          "avg_guesses"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "avg_guesses": {
            "type": "number",
            "format": "double"
          },
          "games_played": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "wins": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "LetterResult": {
        "type": "string",
        "enum": [
          "correct",
          "present",
          "absent"
        ]
      },
      "LobbyConfig": {
        "type": "object",
        "description": "A single PvP lobby: one Circles group's wrapper token and stake. The escrow\nis group-agnostic, so each lobby is an independent `(resolver, token, amount,\ncapacity)` bucket keyed on the wrapper token.",
        "required": [
          "name",
          "group",
          "token",
          "amount",
          "capacity",
          "botFunded"
        ],
        "properties": {
          "amount": {
            "type": "string",
            "description": "Per-player stake (wei, as a decimal string) for `escrow.join`."
          },
          "botFunded": {
            "type": "boolean",
            "description": "Live: the bot Safe holds ≥ 2× `amount` of `token` (headroom so two\nsimultaneous joiners are both covered). Stamped per-request from shared\nstate the bot refreshes each tick; `false` until the first tick."
          },
          "capacity": {
            "type": "integer",
            "format": "int32",
            "description": "Number of players per PvP game (the escrow lobby capacity).",
            "minimum": 0
          },
          "group": {
            "type": "string",
            "description": "Group avatar address. Intersected with a player's Circles group\nmemberships to decide whether the lobby is shown to them."
          },
          "name": {
            "type": "string",
            "description": "Human-readable group name, e.g. \"Gnosis\"."
          },
          "token": {
            "type": "string",
            "description": "s-gCRC wrapper token a player stakes to join this lobby."
          }
        }
      },
      "PlayerGuess": {
        "type": "object",
        "required": [
          "word",
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LetterResult"
            }
          },
          "word": {
            "type": "string"
          }
        }
      },
      "PvpGameResponse": {
        "type": "object",
        "required": [
          "gameId",
          "status",
          "gameType",
          "capacity",
          "players",
          "timeoutSecs"
        ],
        "properties": {
          "answer": {
            "type": [
              "string",
              "null"
            ]
          },
          "capacity": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "gameId": {
            "type": "string"
          },
          "gameType": {
            "type": "string"
          },
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PvpPlayerStatus"
            }
          },
          "status": {
            "type": "string"
          },
          "timeoutSecs": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "PvpPlayerStatus": {
        "type": "object",
        "required": [
          "address",
          "status",
          "guessCount"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "guessCount": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PvpTranscript": {
        "type": "object",
        "required": [
          "gameId",
          "status",
          "answer",
          "players"
        ],
        "properties": {
          "answer": {
            "type": "string"
          },
          "gameId": {
            "type": "string"
          },
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PvpTranscriptPlayer"
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PvpTranscriptGuess": {
        "type": "object",
        "required": [
          "word",
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LetterResult"
            }
          },
          "word": {
            "type": "string"
          }
        }
      },
      "PvpTranscriptPlayer": {
        "type": "object",
        "required": [
          "address",
          "solved",
          "guessCount",
          "guesses"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "guessCount": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "guesses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PvpTranscriptGuess"
            }
          },
          "solved": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
