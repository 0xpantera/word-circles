# Rust backend URL (server-side only, never exposed to the browser).
# Local development:
API_URL=http://localhost:3001

# PvP rollout requires BOTH sides to opt in: the frontend build-time flag below
# AND the backend's PVP_ENABLED (further down), which the frontend reads at
# runtime via /api/config. The PvP UI stays dark unless both are true, so the
# frontend can hold PvP back even when the backend is live. Changing the
# frontend flag requires a rebuild (it's a NEXT_PUBLIC_ var, inlined at build).
# NEXT_PUBLIC_PVP_ENABLED=true

# Resolver wallet (optional — enables on-chain transaction submission)
# RESOLVER_PRIVATE_KEY=0x...
# RPC_URL=http://localhost:8545
# COMMITMENT_ADDRESS=0x...
# STATS_ADDRESS=0x...
# ESCROW_ADDRESS=0x...

# PvP (optional). The token/amount/capacity below are the escrow lobby
# parameters the frontend reads from /api/config to build escrow.join().
# PVP_ENABLED=true
# PVP_TOKEN=0x...            # Circles token players stake
# PVP_AMOUNT=1000000000000000000   # per-player stake, wei
# PVP_CAPACITY=2             # players per game (>= 2)
# PVP_TIMEOUT_SECS=10800     # per-player play window (default 3h)

# PvP matchmaking bot (optional). Fills lonely lobbies so a solo player can
# always find a match. The bot plays as a Circles account (Safe) controlled by
# an owner EOA; the Safe must hold PVP_TOKEN.
# BOT_ENABLED=true
# BOT_SAFE_ADDRESS=0x...     # the bot's Circles account (Safe)
# BOT_PRIVATE_KEY=0x...      # an owner/signer EOA of that Safe
# BOT_JOIN_DELAY_SECS=60     # wait before filling a lonely lobby
# BOT_POLL_SECS=15           # matchmaking/play poll interval
