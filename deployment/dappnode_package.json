{
  "name": "word-circles.public.dappnode.eth",
  "version": "0.4.0",
  "upstreamVersion": "0.4.0",
  "shortDescription": "Word Circles game backend",
  "description": "Rust/Axum backend for the Word Circles game. Handles daily game creation, guess evaluation, and persistence via PostgreSQL.",
  "type": "service",
  "architectures": ["linux/amd64"],
  "author": "bh2smith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bh2smith/word-circles"
  },
  "exposable": [
    {
      "name": "Word Circles API",
      "description": "Game backend API",
      "serviceName": "api",
      "port": 3001
    },
    {
      "name": "Swagger UI",
      "description": "API documentation",
      "serviceName": "api",
      "port": 3001,
      "path": "/swagger-ui"
    }
  ],
  "categories": ["Developer tools"],
  "setupWizard": {
    "version": "2",
    "fields": [
      {
        "id": "resolver_pk",
        "target": {
          "type": "environment",
          "name": "RESOLVER_PRIVATE_KEY",
          "service": "api"
        },
        "title": "Resolver Private Key",
        "description": "Hex-encoded private key for the resolver wallet (signs commitments and settlements on-chain)",
        "secret": true,
        "required": true
      },
      {
        "id": "rpc_url",
        "target": {
          "type": "environment",
          "name": "RPC_URL",
          "service": "api"
        },
        "title": "Gnosis RPC URL",
        "description": "RPC endpoint for Gnosis Chain",
        "required": false,
        "default": "http://gnosis-erigon.dappnode:8545"
      },
      {
        "id": "commitment_address",
        "target": {
          "type": "environment",
          "name": "COMMITMENT_ADDRESS",
          "service": "api"
        },
        "title": "WordCommitment Contract Address",
        "description": "Deployed WordCommitment contract address on Gnosis",
        "required": false,
        "default": "0x6e99c40bd8b87290EB977336c4Be8b2106baB08f"
      },
      {
        "id": "stats_address",
        "target": {
          "type": "environment",
          "name": "STATS_ADDRESS",
          "service": "api"
        },
        "title": "WordCircleStats Contract Address",
        "description": "Deployed WordCircleStats contract address on Gnosis",
        "required": false,
        "default": "0xB96413584d7a4e07cc8c238cC4baA3474C956CCF"
      },
      {
        "id": "database_url",
        "target": {
          "type": "environment",
          "name": "DATABASE_URL",
          "service": "api"
        },
        "title": "Database URL",
        "description": "PostgreSQL connection string. Defaults to the bundled postgres container.",
        "required": false,
        "default": "postgres://wordcircles:wordcircles@postgres:5432/wordcircles"
      },
      {
        "id": "pvp_enabled",
        "target": {
          "type": "environment",
          "name": "PVP_ENABLED",
          "service": "api"
        },
        "title": "Enable PvP Mode",
        "description": "Enable PvP matchmaking, escrow games, and related endpoints (requires resolver wallet)",
        "required": false,
        "default": "false"
      }
    ]
  }
}
