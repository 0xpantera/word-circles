{
  "name": "word-circles.public.dappnode.eth",
  "version": "0.1.0",
  "upstreamVersion": "0.1.0",
  "shortDescription": "Word Circles game backend",
  "description": "Rust/Axum backend for the Word Circles game. Handles daily game creation, guess evaluation, and persistence via SQLite.",
  "type": "service",
  "architectures": ["linux/amd64"],
  "author": "bh2smith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bh2smith/word-circles"
  },
  "exposable": [
    {
      "name": "Word Circles API",
      "description": "Game backend API",
      "serviceName": "api",
      "port": 3001
    }
  ],
  "categories": ["Developer tools"],
  "setupWizard": {
    "version": "2",
    "fields": [
      {
        "id": "resolver_pk",
        "target": {
          "type": "environment",
          "name": "RESOLVER_PRIVATE_KEY",
          "service": "api"
        },
        "title": "Resolver Private Key",
        "description": "Hex-encoded private key for the resolver wallet (signs commitments and settlements on-chain)",
        "secret": true,
        "required": true
      },
      {
        "id": "rpc_url",
        "target": {
          "type": "environment",
          "name": "RPC_URL",
          "service": "api"
        },
        "title": "Gnosis RPC URL",
        "description": "RPC endpoint for Gnosis Chain",
        "required": false,
        "default": "http://gnosis-erigon.dappnode:8545"
      },
      {
        "id": "commitment_address",
        "target": {
          "type": "environment",
          "name": "COMMITMENT_ADDRESS",
          "service": "api"
        },
        "title": "WordCommitment Contract Address",
        "description": "Deployed WordCommitment contract address on Gnosis",
        "required": false,
        "default": "0x072f934b7949D2a71EBb420d1147ff9de5E03170"
      },
      {
        "id": "stats_address",
        "target": {
          "type": "environment",
          "name": "STATS_ADDRESS",
          "service": "api"
        },
        "title": "WordCircleStats Contract Address",
        "description": "Deployed WordCircleStats contract address on Gnosis",
        "required": false,
        "default": "0x5f0FD6BDFb9127bc569E94A2c21699301E64477C"
      }
    ]
  }
}
